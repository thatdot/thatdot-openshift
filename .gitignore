# ============================================================
# Secrets — this is a public repo, never commit these
# ============================================================

# Environment files
.env
.env.*

# Keys, certs, keystores
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.truststore
*.crt
*.cer

# Generic secret-shaped patterns
secrets/
**/*-license-secret.yaml
**/*-credentials*
**/*-token*

# Cluster credentials
kubeconfig
kubeconfig.*
pull-secret
pull-secret.*
!create-qe-oidc-credentials-secret.sh
.crc/

# ============================================================
# Helm
# ============================================================
charts/
*.tgz

